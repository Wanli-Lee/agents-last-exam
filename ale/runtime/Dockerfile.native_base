# ale/native-base:0.1.0 — minimal image for native agent execution.
#
# Python 3.12 (Debian slim) + uv + apt build essentials.
# Nothing agent-specific is baked in — per-agent deps are installed at
# container start by `uv sync --all-packages` against the bind-mounted
# ale repo + cua submodule. (Per-agent baked images are a future
# optimization; for now we accept the ~10-20s first-run uv-sync cost
# and rely on `~/.cache/uv` mount to keep subsequent runs fast.)
#
# Build:
#   docker build -t ale/native-base:0.1.0 \
#     -f ale/runtime/Dockerfile.native_base ale/runtime/

FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
        build-essential && \
    rm -rf /var/lib/apt/lists/*

# uv — Python package manager (used at container start to sync agent deps)
RUN pip install --no-cache-dir uv

WORKDIR /work

# DockerExecutor passes an explicit entrypoint:
#   bash -c 'cd /projects/agents-last-exam &&
#            uv sync --all-packages --quiet &&
#            uv run python -m ale.runtime._docker_entry'
# No ENTRYPOINT / CMD baked here.
